# ─── Backend Environment Variables ──────────────────────
# Copy this file to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB (use MongoDB Atlas for production)
MONGODB_URI=mongodb://localhost:27017/malwagifts
# Production: mongodb+srv://user:password@cluster.mongodb.net/malwagifts

# JWT - Change this to a strong random 256-bit secret!
JWT_SECRET=change-this-to-a-very-long-random-secret-key-minimum-32-chars
JWT_EXPIRE=7d

# Admin credentials (use bcrypt hash for password in production)
ADMIN_EMAIL=admin@malwa.in
ADMIN_PASS_HASH=$2b$10$YourBcryptHashHere

# CORS - your frontend domain(s)
CORS_ORIGIN=http://localhost:3000,https://malwagiftandtoys.in

# Razorpay (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXX
RAZORPAY_SECRET=your_razorpay_secret_here

# Email (SMTP for order confirmations)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@malwagiftandtoys.in
SMTP_PASS=your_gmail_app_password

# WhatsApp Business API (optional - for auto notifications)
WHATSAPP_API_TOKEN=your_meta_whatsapp_token
WHATSAPP_PHONE_ID=your_phone_number_id
